FROM node:20-alpine AS marcel

WORKDIR /app
COPY package.json ./
RUN npm install 

COPY public ./public
COPY src ./src

ARG REACT_APP_MODE=vuln
ARG REACT_APP_API_URL=http://localhost:8000
ENV REACT_APP_MODE=$REACT_APP_MODE
ENV REACT_APP_API_URL=$REACT_APP_API_URL

RUN npm run build
#----------------------------------------------------------------
FROM nginx:alpine
COPY --from=marcel /app/build /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
